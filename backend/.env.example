# ==============================================
# AstraMind Backend - Production Environment Template
# ==============================================
# Copy this file to .env and fill in your actual values
# All values marked [REQUIRED] must be set in production

# ===== ENVIRONMENT CONFIGURATION =====
ENV=production  # [REQUIRED] production or development
LOG_LEVEL=INFO

# ===== DATABASE CONFIGURATION =====
# PostgreSQL database connection string (required in production)
DATABASE_URL=postgresql://username:password@host:port/database_name  # [REQUIRED]

# Database pool settings (optimized for production)
DATABASE_POOL_SIZE=20
DATABASE_POOL_MAX_OVERFLOW=40
DATABASE_POOL_RECYCLE_SECONDS=3600

# ===== JWT SECURITY =====
# Generate a secure random secret: openssl rand -base64 64
JWT_SECRET=your-super-secure-jwt-secret-minimum-32-characters-long  # [REQUIRED]
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ===== AI PROVIDER API KEYS =====
# Configure at least one AI provider:

# Groq API Keys (comma-separated, at least one required for production)
GROQ_API_KEYS=your_groq_key_1,your_groq_key_2

# OpenRouter API Keys (comma-separated)
OPENROUTER_API_KEYS=your_openrouter_key_1,your_openrouter_key_2

# Together AI API Keys (comma-separated)
TOGETHER_API_KEYS=your_together_key_1,your_together_key_2

# Mistral AI API Keys (comma-separated)
MISTRAL_API_KEYS=your_mistral_key_1

# Cerebras API Keys (comma-separated)
CEREBRAS_API_KEYS=your_cerebras_key_1

# SiliconFlow (硅基流动) API Keys (comma-separated)
SILICONFLOW_API_KEYS=your_siliconflow_key_1

# Google AI Studio (Gemini) API Keys (comma-separated)
GOOGLE_AI_STUDIO_API_KEYS=your_google_ai_studio_key_1

# Alibaba Bailian (阿里云百炼) API Keys (comma-separated)
ALIBABA_BAILIAN_API_KEYS=your_bailian_key_1

# DeepSeek API Keys (comma-separated)
DEEPSEEK_API_KEYS=your_deepseek_key_1

# xAI (Grok) API Keys (comma-separated)
XAI_API_KEYS=your_xai_key_1

# Anthropic (Claude) API Keys (comma-separated)
ANTHROPIC_API_KEYS=your_anthropic_key_1

# Cohere API Keys (comma-separated)
COHERE_API_KEYS=your_cohere_key_1

# AI21 API Keys (comma-separated)
AI21_API_KEYS=your_ai21_key_1

# Novita AI API Keys (comma-separated)
NOVITA_API_KEYS=your_novita_key_1

# SambaNova API Keys (comma-separated)
SAMBANOVA_API_KEYS=your_sambanova_key_1

# Cloudflare Workers AI
# Required together:
# - CLOUDFLARE_ACCOUNT_ID
# - CLOUDFLARE_API_TOKEN
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# HuggingFace API Key (optional)
HUGGINGFACE_API_KEY=hf_your_huggingface_token

# OpenAI API Key (optional)
OPENAI_API_KEY=your_openai_key

# Optional base URLs (override defaults if needed)
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
TOGETHER_BASE_URL=https://api.together.xyz/v1
MISTRAL_BASE_URL=https://api.mistral.ai/v1
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_BASE_URL=https://api.openai.com/v1
ALIBABA_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
XAI_BASE_URL=https://api.x.ai/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
COHERE_BASE_URL=https://api.cohere.ai/v1
AI21_BASE_URL=https://api.ai21.com/v1
NOVITA_BASE_URL=https://api.novita.ai/v1
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1

# Ollama Configuration (for local model testing)
OLLAMA_URL=http://localhost:11434

# ===== ADMINISTRATION =====
# Comma-separated admin email addresses
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# ===== CORS AND SECURITY =====
# Comma-separated allowed origins for production
ALLOWED_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# ===== RATE LIMITING =====
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_WINDOW_SECONDS=60
USER_DAILY_QUOTA=50
ADMIN_DAILY_QUOTA=500
PREMIUM_DAILY_QUOTA=200
ENABLE_QUOTA_TIERS=true

# ===== REQUEST LIMITS =====
MAX_REQUEST_SIZE_BYTES=50000
REQUEST_TIMEOUT_SECONDS=30

# ===== OUTBOUND HTTP (provider calls) =====
OUTBOUND_HTTP_MAX_CONNECTIONS=2000
OUTBOUND_HTTP_MAX_KEEPALIVE=500
OUTBOUND_HTTP_CONNECT_TIMEOUT_SECONDS=3.0
OUTBOUND_HTTP_READ_TIMEOUT_SECONDS=30.0

# ===== PERSONALITY CONFIGURATION =====
# Path to personality config file (optional)
# PERSONALITY_CONFIG_PATH=./custom_personality.yaml

# Or use a named profile from config/profiles/
# PERSONALITY_PROFILE=professional

# ===== MODEL CONFIGURATION =====
GROQ_FAST_MODEL=llama-3.1-8b-instant
GROQ_BALANCED_MODEL=llama-3.1-70b
OPENROUTER_SMART_MODEL=openai/gpt-4o-mini
OPENROUTER_BALANCED_MODEL=openai/gpt-4-turbo-preview
HF_MODEL_ENDPOINT=https://api-inference.huggingface.co/models/microsoft/DialoGPT-medium

# ===== APP CONFIGURATION =====
APP_URL=https://your-domain.com

# ===== FEATURE FLAGS =====
ENABLE_WEB_SEARCH=true
ENABLE_IMAGE_GENERATION=false

# ===== DEVELOPMENT SETTINGS =====
# Uncomment for development mode:
# ENV=development
# LOG_LEVEL=DEBUG
# ALLOWED_ORIGINS=http://localhost:3000
# DATABASE_URL=sqlite+aiosqlite:///./astramind_local.db

# ===== DEPLOYMENT NOTES =====
# For Render deployment, add these as environment variables in the Render dashboard
# Do not commit actual secrets to version control!
